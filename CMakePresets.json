{
    "version": 3,
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug configuration of the Zagan library",
            "binaryDir": "build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "ZAGAN_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Release configuration of the Zagan library",
            "binaryDir": "build/Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ZAGAN_BUILD_TESTS": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build of the Zagan library",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Release build of the Zagan library",
            "configurePreset": "release"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}